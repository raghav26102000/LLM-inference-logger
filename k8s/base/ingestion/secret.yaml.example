# secret.yaml.example — Copy this to secret.yaml and fill in your keys.
# DO NOT commit secret.yaml to git. It is gitignored.
#
# Values must be base64-encoded. Encode like this:
#   echo -n "your-actual-key" | base64
#
# Leave a value as "" if you don't have that key.
# The proxy will return a 503 for unconfigured providers.

apiVersion: v1
kind: Secret
metadata:
  name: llm-api-keys
  namespace: llm-logger
type: Opaque
data:
  # echo -n "sk-ant-..." | base64
  ANTHROPIC_API_KEY: ""

  # echo -n "sk-..." | base64
  OPENAI_API_KEY: ""

  # echo -n "gsk_..." | base64
  GROQ_API_KEY: ""

  # echo -n "AIzaSy..." | base64
  GEMINI_API_KEY: ""

  # echo -n "sk-..." | base64
  DEEPSEEK_API_KEY: ""

  # Postgres password — must match postgres StatefulSet env
  # echo -n "changeme-in-prod" | base64
  POSTGRES_PASSWORD: "Y2hhbmdlbWUtaW4tcHJvZA=="
